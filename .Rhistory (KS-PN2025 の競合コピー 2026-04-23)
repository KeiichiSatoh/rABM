# ---------------------------------------------------------
# Baseline 1: apply + sample()
# size >= 2 supported via repeated sampling without replacement
# ---------------------------------------------------------
sample_apply <- function(x, size = 1){
if (is.null(colnames(x))) colnames(x) <- paste0("x", 1:ncol(x))
col_names <- colnames(x)
if (size == 1) {
return(apply(x, 1, function(prob){
col_names[sample.int(length(prob), size = 1, prob = prob)]
}))
}
out <- apply(x, 1, function(prob){
col_names[sample.int(length(prob), size = size, prob = prob, replace = FALSE)]
})
t(out)
}
# ---------------------------------------------------------
# Baseline 2: explicit for + sample()
# size >= 2 supported via repeated sampling without replacement
# ---------------------------------------------------------
sample_for <- function(x, size = 1){
if (is.null(colnames(x))) colnames(x) <- paste0("x", 1:ncol(x))
col_names <- colnames(x)
n_cases <- nrow(x)
if (size == 1) {
out <- character(n_cases)
for(i in 1:n_cases){
out[i] <- col_names[sample.int(ncol(x), size = 1, prob = x[i, ])]
}
return(out)
}
out <- matrix(NA_character_, nrow = n_cases, ncol = size)
for(i in 1:n_cases){
out[i, ] <- col_names[sample.int(ncol(x), size = size, prob = x[i, ], replace = FALSE)]
}
dimnames(out) <- list(rownames(x), 1:size)
out
}
# ---------------------------------------------------------
# Data generator
# Positive weights only
# ---------------------------------------------------------
make_prob_matrix <- function(n_cases = 10000, n_choices = 10, seed = 123){
set.seed(seed)
x <- matrix(
rexp(n_cases * n_choices, rate = 1),
nrow = n_cases,
ncol = n_choices
)
colnames(x) <- paste0("x", 1:n_choices)
x
}
# ---------------------------------------------------------
# Benchmark one condition
# ---------------------------------------------------------
benchmark_one <- function(n_cases, n_choices, size, times = 20L, seed = 123){
x <- make_prob_matrix(
n_cases   = n_cases,
n_choices = n_choices,
seed      = seed
)
# warm up
invisible(sample_weighted(x, size = size))
invisible(sample_apply(x, size = size))
invisible(sample_for(x, size = size))
bm <- microbenchmark(
sample_weighted = sample_weighted(x, size = size),
apply_sample    = sample_apply(x, size = size),
for_sample      = sample_for(x, size = size),
times = times,
unit = "ms"
)
out <- summary(bm)
out$n_cases   <- n_cases
out$n_choices <- n_choices
out$size      <- size
out
}
# ---------------------------------------------------------
# Run grid benchmark
# ---------------------------------------------------------
run_benchmark_grid <- function(
n_cases_vec   = c(1000, 5000, 10000),
n_choices_vec = c(5, 10, 20, 50),
size_vec      = c(1, 2, 3),
times         = 20L,
seed          = 123
){
res <- vector("list", length(n_cases_vec) * length(n_choices_vec) * length(size_vec))
idx <- 1L
for(n_cases in n_cases_vec){
for(n_choices in n_choices_vec){
for(size in size_vec){
cat("Running:",
"n_cases =", n_cases,
"| n_choices =", n_choices,
"| size =", size, "\n")
res[[idx]] <- benchmark_one(
n_cases   = n_cases,
n_choices = n_choices,
size      = size,
times     = times,
seed      = seed
)
idx <- idx + 1L
}
}
}
out <- do.call(rbind, res)
rownames(out) <- NULL
out
}
# ---------------------------------------------------------
# Summarize relative speed
# ---------------------------------------------------------
summarize_speedup <- function(bm_grid){
keep <- bm_grid[, c("expr", "median", "mean", "n_cases", "n_choices", "size")]
split_key <- interaction(keep$n_cases, keep$n_choices, keep$size, drop = TRUE)
groups <- split(keep, split_key)
out <- lapply(groups, function(df){
med_fast  <- df$median[df$expr == "sample_weighted"]
med_apply <- df$median[df$expr == "apply_sample"]
med_for   <- df$median[df$expr == "for_sample"]
data.frame(
n_cases = df$n_cases[1],
n_choices = df$n_choices[1],
size = df$size[1],
median_fast = med_fast,
median_apply = med_apply,
median_for = med_for,
speedup_vs_apply = med_apply / med_fast,
speedup_vs_for = med_for / med_fast
)
})
do.call(rbind, out)
}
