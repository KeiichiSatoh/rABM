library(matrixStats)
library(microbenchmark)
# ---------------------------------------------------------
# Baseline: apply + sample()
# Each row draws one category according to row-specific prob
# ---------------------------------------------------------
sample_apply <- function(x){
if (is.null(colnames(x))) colnames(x) <- paste0("x", 1:ncol(x))
col_names <- colnames(x)
apply(x, 1, function(prob){
col_names[sample.int(n = length(prob), size = 1, prob = prob)]
})
}
# ---------------------------------------------------------
# Alternative baseline: explicit for-loop + sample()
# Sometimes useful because apply itself has overhead
# ---------------------------------------------------------
sample_for <- function(x){
if (is.null(colnames(x))) colnames(x) <- paste0("x", 1:ncol(x))
col_names <- colnames(x)
n_cases <- nrow(x)
out <- character(n_cases)
for(i in 1:n_cases){
out[i] <- col_names[sample.int(n = ncol(x), size = 1, prob = x[i, ])]
}
out
}
# ---------------------------------------------------------
# Generate test matrix
# Positive weights only, row sums > 0 guaranteed
# ---------------------------------------------------------
make_prob_matrix <- function(n_cases = 10000, n_choices = 10, seed = 123){
set.seed(seed)
x <- matrix(
rexp(n_cases * n_choices, rate = 1),
nrow = n_cases,
ncol = n_choices
)
colnames(x) <- paste0("x", 1:n_choices)
x
}
